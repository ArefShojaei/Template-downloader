<?php

require_once __DIR__ . "/vendor/autoload.php";


use Spider\Spider;
use PhpX\{
    Components\Console\App,
    Utils\Console\Console
};
use App\Utils\{
    Client,
    Http
};


$app = new App;

$app->command("template {url}", function(string $url) {
    $html = Http::get($url);

    $html = Client::replaceRelativePathToAbsolutePath($html, $url);
    
    $spider = new Spider;
    
    $page = $spider->loadHTML($html);


    $client = new Client($page, $url);

    $client->setDomainFromURL();
    
    $client->removeAdditionalMetaTags();

    $client->removeAdditionalLinkTags();

    $client->setCssAssetLinks();

    $client->setScriptAssetLinks();

    $client->setMediaAssetLinks();

    $client->replaceExternalLinksToHashedValue();

    $client->saveAssets();

    $client->saveFile();


    return Console::info("Template saved.");
});

$app->launch();