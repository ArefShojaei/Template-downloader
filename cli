<?php

require_once __DIR__ . "/vendor/autoload.php";


use Spider\Spider;
use PhpX\{
    Components\Console\App,
    Utils\Console\Console
};
use App\Client;
use App\Utils\Http;
use function App\replaceRelativeToAbsolutePath;


$app = new App;

$app->command("template {url}", function(string $url) {
    $html = Http::get($url);

    $html = replaceRelativeToAbsolutePath($html, $url);
    
    $spider = new Spider;
    
    $page = $spider->loadHTML($html);

    $client = new Client($page, $url);

    $client->setDomainFromURL();
    
    $client->changeAdditionalTags();
    
    $client->changeExternalLinks();
    
    $client->setAssets();

    $client->saveTemplate();


    return Console::info("Template saved.");
});

$app->launch();